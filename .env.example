# --- API Riot (obligatoire) ---
RIOT_API_KEY=RGAPI-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
RIOT_PLATFORM=euw1     # euw1, eun1, na1, kr...
RIOT_REGION=europe     # europe, americas, asia

# --- Stockage ---
# Sur Vercel : renseigne ces 2 variables (intégration Upstash/Vercel KV) => stockage KV.
# En local/Docker : laisse-les vides => repli automatique sur des fichiers JSON.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Rafraîchissement (toutes les 10 min via cron externe) ---
# Secret protégeant /api/refresh. Le cron externe appelle :
#   https://<ton-site>/api/refresh?key=<REFRESH_SECRET>
REFRESH_SECRET=mets-un-secret-aleatoire-ici
# (Le Cron Vercel utilise automatiquement CRON_SECRET si tu le définis.)
